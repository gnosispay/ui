    "@rainbow-me/rainbowkit": "2.2.11",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-query": "5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "4.4.0",
    "jwt-decode": "4.0.0",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
